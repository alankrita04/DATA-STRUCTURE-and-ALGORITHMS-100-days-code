//Problem Statement : Given an array of integers containing both positive and negative values, find the length of the longest contiguous subarray whose sum is equal to zero.

#include <stdio.h>

#define MAX 1000

struct Map {
    int sum;
    int index;
};

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    struct Map map[MAX];
    int size = 0;

    int prefixSum = 0, maxLen = 0;

    for (int i = 0; i < n; i++) {
        prefixSum += arr[i];

        if (prefixSum == 0) {
            maxLen = i + 1;
        }

        int found = -1;
        for (int j = 0; j < size; j++) {
            if (map[j].sum == prefixSum) {
                found = j;
                break;
            }
        }

        if (found != -1) {
            int len = i - map[found].index;
            if (len > maxLen)
                maxLen = len;
        } else {
            map[size].sum = prefixSum;
            map[size].index = i;
            size++;
        }
    }

    printf("%d\n", maxLen);

    return 0;
}
