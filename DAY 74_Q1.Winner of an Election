//Problem Statement : Given an array of candidate names where each name represents a vote cast for that candidate, determine the candidate who received the maximum number of votes. In case of a tie, return the lexicographically smallest candidate name.

#include <stdio.h>
#include <string.h>

#define MAX 1000
#define NAME_LEN 50

// Structure to store candidate and vote count
struct Candidate {
    char name[NAME_LEN];
    int count;
};

int main() {
    int n;
    scanf("%d", &n);

    char votes[MAX][NAME_LEN];
    for (int i = 0; i < n; i++) {
        scanf("%s", votes[i]);
    }

    struct Candidate candidates[MAX];
    int size = 0;

    // Count votes
    for (int i = 0; i < n; i++) {
        int found = -1;

        for (int j = 0; j < size; j++) {
            if (strcmp(candidates[j].name, votes[i]) == 0) {
                found = j;
                break;
            }
        }

        if (found != -1) {
            candidates[found].count++;
        } else {
            strcpy(candidates[size].name, votes[i]);
            candidates[size].count = 1;
            size++;
        }
    }

    // Find winner
    char winner[NAME_LEN];
    int maxVotes = 0;

    for (int i = 0; i < size; i++) {
        if (candidates[i].count > maxVotes) {
            maxVotes = candidates[i].count;
            strcpy(winner, candidates[i].name);
        } 
        else if (candidates[i].count == maxVotes) {
            if (strcmp(candidates[i].name, winner) < 0) {
                strcpy(winner, candidates[i].name);
            }
        }
    }

    // Output
    printf("%s %d\n", winner, maxVotes);

    return 0;
}
