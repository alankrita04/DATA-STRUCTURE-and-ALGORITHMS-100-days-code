//Problem Statement : Given weighted undirected graph, compute total weight of Minimum Spanning Tree using Prim’s algorithm.

#include <stdio.h>
#include <limits.h>

#define MAX 100

int main() {
    int n, m;
    scanf("%d %d", &n, &m);

    int graph[MAX][MAX];

    // Initialize graph with large values
    for (int i = 1; i <= n; i++) {
        for (int j = 1; j <= n; j++) {
            graph[i][j] = INT_MAX;
        }
    }

    // Input edges
    for (int i = 0; i < m; i++) {
        int u, v, w;
        scanf("%d %d %d", &u, &v, &w);
        graph[u][v] = w;
        graph[v][u] = w;
    }

    int selected[MAX] = {0};
    int minEdge[MAX];

    // Initialize
    for (int i = 1; i <= n; i++) {
        minEdge[i] = INT_MAX;
    }

    minEdge[1] = 0; // start from node 1
    int totalWeight = 0;

    for (int i = 1; i <= n; i++) {
        int u = -1;

        // Pick minimum edge
        for (int j = 1; j <= n; j++) {
            if (!selected[j] && (u == -1 || minEdge[j] < minEdge[u])) {
                u = j;
            }
        }

        selected[u] = 1;
        totalWeight += minEdge[u];

        // Update neighbors
        for (int v = 1; v <= n; v++) {
            if (graph[u][v] != INT_MAX && !selected[v] && graph[u][v] < minEdge[v]) {
                minEdge[v] = graph[u][v];
            }
        }
    }

    printf("%d\n", totalWeight);

    return 0;
}
