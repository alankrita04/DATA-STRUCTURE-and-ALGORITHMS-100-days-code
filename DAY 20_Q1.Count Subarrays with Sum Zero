//Problem: Given an array of integers, count the number of subarrays whose sum is equal to zero.

#include <stdio.h>
#include <stdlib.h>

#define MAX 100000

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int sum = 0, count = 0;

    int *freq = (int *)calloc(2 * MAX + 1, sizeof(int));

    int offset = MAX;

    freq[offset] = 1; // sum = 0 initially

    for(int i = 0; i < n; i++) {
        sum += arr[i];

        // If this sum has been seen before
        if(freq[sum + offset] > 0) {
            count += freq[sum + offset];
        }

        freq[sum + offset]++;
    }

    printf("%d\n", count);

    free(freq);
    return 0;
}
